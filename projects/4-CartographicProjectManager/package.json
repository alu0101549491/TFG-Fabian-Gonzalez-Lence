{
  "name": "cartographic-project-manager",
  "version": "1.0.0",
  "description": "Web and mobile application for comprehensive management of cartographic projects with collaboration, task tracking, messaging, and Dropbox integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs": "typedoc",
    "type-check": "vue-tsc --noEmit"
  },
  "keywords": [
    "cartographic",
    "project-management",
    "vue",
    "typescript",
    "vite",
    "pinia",
    "socket.io",
    "dropbox"
  ],
  "author": "Fabián González Lence",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "pinia": "^2.3.0",
    "socket.io-client": "^4.8.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/vue": "^8.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.15.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-vue": "^9.31.0",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.26.10",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^7.3.0",
    "vue-tsc": "^2.2.0"
  }
}
