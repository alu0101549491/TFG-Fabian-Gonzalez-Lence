{
  "name": "cartographic-project-manager",
  "version": "1.0.0",
  "description": "Web and mobile application for comprehensive management of cartographic projects",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
