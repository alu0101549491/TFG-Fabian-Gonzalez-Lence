# Cartographic Project Manager - Frontend Environment Variables (Example)

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api/v1

# WebSocket Configuration
VITE_SOCKET_URL=http://localhost:3000

# Application Version
VITE_APP_VERSION=1.0.0

# --------------------------------------------
# Playwright E2E (optional)
# --------------------------------------------
# The E2E suite logs in with seeded dev accounts.
# Passwords are REQUIRED (no defaults) to avoid hardcoding secrets.
PW_E2E_ADMIN_PASSWORD=
PW_E2E_CLIENT_PASSWORD=
PW_E2E_SPECIAL_PASSWORD=

# Emails are optional (defaults match seeded dev accounts)
PW_E2E_ADMIN_EMAIL=admin@cartographic.com
PW_E2E_CLIENT_EMAIL=client@example.com
PW_E2E_SPECIAL_EMAIL=special@cartographic.com

# Optional base URLs for Playwright helpers
# PLAYWRIGHT_BASE_URL=http://localhost:5173/4-CartographicProjectManager/
# PW_API_BASE_URL=http://localhost:3000/api/v1/

# Optional: where Playwright writes authenticated storage states
# PW_AUTH_DIR=/tmp/cpm-playwright-auth
