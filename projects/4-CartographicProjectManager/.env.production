# Cartographic Project Manager - Frontend Production Environment

# API Configuration
# ⚠️ This will be set by GitHub Actions during deployment
# Replace with your actual Railway backend URL after deployment
VITE_API_BASE_URL=https://YOUR_RAILWAY_APP_NAME.up.railway.app/api/v1

# WebSocket Configuration  
VITE_SOCKET_URL=https://YOUR_RAILWAY_APP_NAME.up.railway.app

# Application Version
VITE_APP_VERSION=1.0.0

# Environment
NODE_ENV=production
