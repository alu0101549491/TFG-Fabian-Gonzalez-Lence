 * @file presentation/pages/admin/disputed-matches/disputed-matches.component.css
 * @desc Styling for disputed matches admin page matching My Matches design
 * @see {@link https://github.com/alu0101549491/TFG-Fabian-Gonzalez-Lence/tree/main/projects/5-TennisTournamentManager}
 */

.disputed-matches-container {
  min-height: 100vh;
  background: var(--color-gray-50);
}

/* Hero Section */
.hero-section {
  position: relative;
  background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 50%, var(--color-secondary) 100%);
  color: var(--color-white);
  padding: 4rem 0 3rem;
  overflow: hidden;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 600"><circle cx="100" cy="100" r="80" fill="rgba(255,255,255,0.05)"/><circle cx="900" cy="400" r="120" fill="rgba(255,255,255,0.03)"/><circle cx="600" cy="300" r="100" fill="rgba(255,255,255,0.04)"/></svg>');
  background-size: cover;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: var(--max-content-width);
  margin: 0 auto;
  padding: 0 var(--spacing-lg);
  text-align: center;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-xl);
  text-align: left;
}

.back-button {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  color: var(--color-white);
  border: 1px solid rgba(255, 255, 255, 0.3);
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--border-radius-md);
  font-weight: var(--font-weight-semibold);
  cursor: pointer;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-sm);
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  font-size: var(--font-size-base);
}

.back-button:hover {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.5);
  transform: translateX(-4px);
}

.hero-title {
  font-size: 3rem;
  font-weight: var(--font-weight-bold);
  margin: 0 0 var(--spacing-sm) 0;
  color: var(--color-white);
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4), 
               0 4px 8px rgba(0, 0, 0, 0.3),
               0 1px 2px rgba(0, 0, 0, 0.5);
}

.hero-subtitle {
  font-size: var(--font-size-lg);
  color: var(--color-white);
  margin: 0;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4), 
               0 3px 6px rgba(0, 0, 0, 0.3);
}

/* Main Content */
.main-content {
  max-width: var(--max-content-width);
  margin: 0 auto;
  padding: var(--spacing-2xl) var(--spacing-lg);
}

/* Loading State */
.loading-state {
  text-align: center;
  padding: var(--spacing-2xl);
}

.spinner {
  width: 50px;
  height: 50px;
  border: 4px solid var(--color-gray-200);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto var(--spacing-md);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-state p {
  color: var(--color-gray-600);
  font-size: var(--font-size-base);
}

/* Error & Empty States */
.error-banner, .empty-state {
  text-align: center;
  padding: var(--spacing-2xl);
  background: var(--color-white);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-sm);
  max-width: 600px;
  margin: 0 auto;
}

.error-icon, .empty-icon {
  font-size: 4rem;
  margin-bottom: var(--spacing-md);
}

.error-banner .error-icon {
  color: var(--color-error);
}

.empty-icon {
  color: var(--color-success);
}

.empty-subtitle {
  color: var(--color-gray-600);
  margin-top: var(--spacing-sm);
  font-size: var(--font-size-sm);
}

.btn-primary {
  margin-top: var(--spacing-md);
}

/* Disputed List */
.disputed-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

/* Dispute Card */
.dispute-card {
  background: var(--color-white);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-md);
  border-left: 4px solid var(--color-warning);
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}

.dispute-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.dispute-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-bottom: 1px solid #fcd34d;
}

.match-info {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  flex-wrap: wrap;
}

.match-info h3 {
  margin: 0;
  font-size: var(--font-size-xl);
  color: var(--color-gray-900);
  font-weight: var(--font-weight-semibold);
}

.dispute-badge {
  background: var(--color-warning);
  color: var(--color-gray-900);
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--border-radius-full);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}

.dispute-date {
  color: var(--color-gray-600);
  font-size: var(--font-size-sm);
}

.dispute-body {
  padding: var(--spacing-lg);
}

/* Participants */
.participants {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
  padding: var(--spacing-md);
  background: var(--color-gray-50);
  border-radius: var(--border-radius-md);
  margin-bottom: var(--spacing-md);
}

.participant {
  flex: 1;
  text-align: center;
}

.participant strong {
  color: var(--color-gray-900);
  font-size: var(--font-size-base);
}

.vs {
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-600);
  font-size: var(--font-size-lg);
}

.winner-badge {
  display: inline-block;
  margin-top: var(--spacing-xs);
  background: linear-gradient(135deg, var(--color-warning) 0%, var(--color-warning-dark) 100%);
  color: var(--color-white);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--border-radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

/* Result Info */
.result-info {
  margin-bottom: var(--spacing-md);
}

.info-box {
  display: flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-info-light);
  border-left: 3px solid var(--color-info);
  border-radius: var(--border-radius-sm);
}

/* Dispute Reason */
.dispute-reason {
  background: var(--color-warning-light);
  border-left: 3px solid var(--color-warning);
  padding: var(--spacing-md);
  border-radius: var(--border-radius-sm);
  margin-bottom: var(--spacing-md);
}

.dispute-reason strong {
  color: var(--color-gray-900);
  font-weight: var(--font-weight-semibold);
}

.dispute-reason p {
  margin: var(--spacing-xs) 0 0;
  color: var(--color-warning-dark);
  font-style: italic;
}

.player-comments {
  background: var(--color-gray-100);
  padding: var(--spacing-md);
  border-radius: var(--border-radius-sm);
}

.player-comments strong {
  color: var(--color-gray-900);
}

.player-comments p {
  margin: var(--spacing-xs) 0 0;
  color: var(--color-gray-700);
}

/* Dispute Actions */
.dispute-actions {
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-gray-50);
  border-top: 1px solid var(--color-gray-200);
  display: flex;
  justify-content: flex-end;
}

.btn-resolve {
  background: linear-gradient(135deg, var(--color-success) 0%, var(--color-success-dark) 100%);
  color: var(--color-white);
  border: none;
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--border-radius-md);
  font-weight: var(--font-weight-semibold);
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  font-size: var(--font-size-base);
}

.btn-resolve:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
}

/* Modal */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: var(--spacing-lg);
}

.modal-content {
  background: var(--color-white);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-2xl);
  max-width: 600px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--color-gray-200);
  background: linear-gradient(135deg, var(--color-gray-50) 0%, var(--color-white) 100%);
}

.modal-header h3 {
  margin: 0;
  font-size: var(--font-size-2xl);
  color: var(--color-gray-900);
  font-weight: var(--font-weight-bold);
}

.close-btn {
  background: var(--color-gray-100);
  border: none;
  font-size: var(--font-size-2xl);
  cursor: pointer;
  color: var(--color-gray-600);
  line-height: 1;
  padding: 0;
  width: 32px;
  height: 32px;
  border-radius: var(--border-radius-full);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn:hover {
  background: var(--color-gray-200);
  color: var(--color-gray-900);
}

.modal-body {
  padding: var(--spacing-lg);
}

.modal-match-info {
  background: var(--color-gray-50);
  padding: var(--spacing-md);
  border-radius: var(--border-radius-md);
  margin-bottom: var(--spacing-lg);
}

.modal-match-info p {
  margin: var(--spacing-xs) 0;
  color: var(--color-gray-700);
}

.dispute-reason-modal {
  margin-top: var(--spacing-sm);
  color: var(--color-gray-600);
  font-size: var(--font-size-sm);
}

.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-group label {
  display: block;
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-xs);
  color: var(--color-gray-900);
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.radio-label {
  display: flex !important;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-gray-50);
  border: 2px solid var(--color-gray-200);
  border-radius: var(--border-radius-md);
  cursor: pointer;
  transition: all 0.2s;
}

.radio-label:hover {
  background: var(--color-gray-100);
  border-color: var(--color-primary);
}

.radio-label input[type="radio"]:checked + span,
.radio-label:has(input[type="radio"]:checked) {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.form-input, .form-textarea {
  width: 100%;
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid var(--color-gray-300);
  border-radius: var(--border-radius-md);
  font-size: var(--font-size-base);
  font-family: inherit;
  transition: all 0.2s ease;
}

.form-input:focus, .form-textarea:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px var(--color-primary-light);
}

/* Annul Section */
.annul-section {
  margin-top: var(--spacing-xl);
  padding-top: var(--spacing-lg);
  border-top: 2px dashed var(--color-gray-200);
}

.annul-section h4 {
  margin: 0 0 var(--spacing-sm);
  color: var(--color-error);
  font-weight: var(--font-weight-semibold);
}

.annul-note {
  color: var(--color-gray-600);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-md);
}

/* Modal Footer */
.modal-footer {
  display: flex;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
  border-top: 1px solid var(--color-gray-200);
  justify-content: flex-end;
  background: var(--color-gray-50);
}

.btn-primary, .btn-secondary, .btn-annul {
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--border-radius-md);
  font-weight: var(--font-weight-semibold);
  cursor: pointer;
  border: none;
  transition: all 0.2s ease;
  font-size: var(--font-size-base);
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-white);
}

.btn-primary:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.btn-secondary {
  background: var(--color-gray-200);
  color: var(--color-gray-900);
}

.btn-secondary:hover:not(:disabled) {
  background: var(--color-gray-300);
}

.btn-annul {
  background: var(--color-error);
  color: var(--color-white);
}

.btn-annul:hover:not(:disabled) {
  background: var(--color-error-dark);
  transform: translateY(-1px);
}

.btn-primary:disabled, .btn-secondary:disabled, .btn-annul:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
}

/* Responsive */
@media (max-width: 768px) {
  .participants {
    flex-direction: column;
  }

  .modal-footer {
    flex-direction: column;
  }

  .modal-footer button {
    width: 100%;
  }
}
