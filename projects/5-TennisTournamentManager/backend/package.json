{
  "name": "tennis-tournament-manager-backend",
  "version": "1.0.0",
  "description": "Backend API server for Tennis Tournament Manager",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:clean": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true && npm run dev",
    "kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "build": "tsc",
    "build:deploy": "tsc || true",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:seed": "tsx src/infrastructure/database/seed.ts",
    "db:add-categories": "tsx src/infrastructure/database/add-categories.ts",
    "setup:test-tournament": "tsx scripts/setup-test-tournament.ts",
    "setup:phase-linking": "tsx scripts/setup-phase-linking-test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "tennis",
    "tournament",
    "api",
    "express",
    "typescript",
    "postgresql"
  ],
  "author": "Fabián González Lence",
  "license": "MIT",
  "dependencies": {
    "@types/pdfkit": "^0.17.5",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-stringify": "^6.7.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.5",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.7.2",
    "typeorm": "^0.3.20",
    "web-push": "^3.6.7",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
