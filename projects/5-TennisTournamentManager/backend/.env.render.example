# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Render Environment Variables Template - Tennis Tournament Manager
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 📋 INSTRUCTIONS:
# Copy these variables to Render Dashboard → Environment tab
# Some values are auto-generated by render.yaml
# Others must be set manually (marked with ⚠️)
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━ Server Configuration ━━━━
NODE_ENV=production
PORT=10000
API_PREFIX=/api
API_VERSION=v1

# ━━━━ Database Configuration ━━━━
# ⚠️ AUTO-GENERATED: Connected via render.yaml
DATABASE_URL=postgresql://user:password@host:5432/tennis_tournament_manager

# TypeORM Settings
DB_SYNCHRONIZE=false  # NEVER true in production
DB_LOGGING=false
DB_SSL=true

# ━━━━ JWT Configuration ━━━━
# ⚠️ AUTO-GENERATED: Render creates these secrets automatically
JWT_SECRET=auto-generated-by-render
JWT_REFRESH_SECRET=auto-generated-by-render
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ━━━━ CORS Configuration ━━━━
# ⚠️ MANUAL: Set to your GitHub Pages URL
CORS_ORIGIN=https://your-username.github.io
SOCKET_CORS_ORIGIN=https://your-username.github.io

# ━━━━ Rate Limiting ━━━━
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ━━━━ WebSocket Configuration ━━━━
WS_PORT=10000  # Same as PORT in Render

# ━━━━ Email Configuration (SMTP) ━━━━
# ⚠️ MANUAL: Configure your email service
# Gmail example: use App Password (not regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false  # true for port 465, false for 587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM_NAME=Tennis Tournament Manager
EMAIL_FROM_ADDRESS=your-email@gmail.com

# ⚠️ MANUAL: Set to your frontend URL
APP_URL=https://your-username.github.io

# ━━━━ Telegram Configuration ━━━━
# ⚠️ OPTIONAL: Get token from @BotFather on Telegram
# Leave empty to disable Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false

# ━━━━ Web Push Configuration (PWA Notifications) ━━━━
# ⚠️ OPTIONAL: Generate with: npx web-push generate-vapid-keys
# Leave empty to disable Web Push notifications
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:your-email@example.com
WEB_PUSH_ENABLED=false

# ━━━━ Logging Configuration ━━━━
LOG_LEVEL=info  # error, warn, info, debug
LOG_FORMAT=json  # json or simple

# ━━━━ File Upload Configuration ━━━━
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ━━━━ Session Configuration ━━━━
SESSION_TIMEOUT_MINUTES=60

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 SETUP NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 1. REQUIRED (must configure in Render):
#    - CORS_ORIGIN, SOCKET_CORS_ORIGIN
#    - EMAIL_* variables (for notifications)
#    - APP_URL
#
# 2. OPTIONAL (only if using these features):
#    - TELEGRAM_BOT_TOKEN (for Telegram notifications)
#    - WEB_PUSH_* keys (for PWA push notifications)
#
# 3. AUTO-GENERATED (don't need to set manually):
#    - DATABASE_URL (linked from tennis-db)
#    - JWT_SECRET, JWT_REFRESH_SECRET
#    - PORT (always 10000 on Render)
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐 SECURITY NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# - NEVER commit .env files to Git
# - Use strong, unique secrets in production
# - For Gmail: enable 2FA and use App Passwords
# - Rotate JWT secrets periodically
# - Keep VAPID keys secure (treat like passwords)
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
