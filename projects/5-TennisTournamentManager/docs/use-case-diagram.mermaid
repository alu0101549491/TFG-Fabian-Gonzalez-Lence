    %% Include relationships - User Management
    ManageUsers -.->|includes| CreateUser
    ManageUsers -.->|includes| EditUser
    ManageUsers -.->|includes| DeleteUser
    
    CreateUser -.->|includes| AssignRoles
    EditUser -.->|includes| ManagePermissions
    
    %% Include relationships - Tournament Management
    CreateTournament -.->|includes| ConfigureTournament
    CreateTournament -.->|includes| ValidateData
    CreateTournament -.->|includes| UpdateUI
    
    ConfigureTournament -.->|includes| EditTournamentDetails
    ConfigureTournament -.->|includes| DefineTournamentRules
    ConfigureTournament -.->|includes| ManageCourtAvailability
    
    %% Include relationships - Registration
    RegisterParticipant -.->|includes| ValidateData
